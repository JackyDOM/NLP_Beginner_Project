import * as z from 'zod';

export const memberSchema = z
  .object({
    spid: z.string().optional(),

    equity_card_number: z
      .string()
      .min(10, { message: 'សូមបំពេញលេខបណ្ណសមធម៌អោយបានត្រឹមត្រូវ' }),

    head_of_household: z.string(),

    member_selected: z
      .string()
      .min(1, { message: 'សូមជ្រើសរើសឈ្មោះម្ចាស់គណនី' }),

    // National ID
    national_id: z
      .string()
      .regex(/^\d+$/, {
        message: 'សូមបញ្ចូលលេខអត្តសញ្ញាណបណ្ណជាលេខប៉ុណ្ណោះ',
      }),

    phone_number: z
      .string()
      .refine(value => !value || /^(0[1-9])[0-9]{7,8}$/.test(value), {
        message: 'សូមបញ្ចូលលេខទូរសព្ទ ចាប់ផ្តើមដោយលេខ ០ និងមាន ៩ ឬ ១០ខ្ទង់',
      })
      .optional()
      .nullable(),

    dob: z.string().min(1, { message: 'សូមបំពេញថ្ងៃខែឆ្នាំកំណើត' }),

    gender: z
      .string()
      .min(1, { message: 'សូមជ្រើសរើសភេទ' }),

    status: z
      .string()
      .min(1, { message: 'សូមជ្រើសរើសស្ថានភាព' }),

    name_en: z
      .string()
      .optional()
      .refine(
        value => {
          if (!value) return true;
          return value.length >= 3 && /^[A-Z\s]+$/.test(value);
        },
        {
          message:
            'ឈ្មោះជាអក្សរឡាតាំងត្រូវតែមានយ៉ាងហោចណាស់ ៣អក្សរ និងជាអក្សរអង់គ្លេសប៉ុណ្ណោះ (A-Z, space)',
        },
      ),

    account_holder_photo: z
      .string()
      .min(1, 'សូមថតរូបម្ចាស់គណនី')
      .url('Invalid photo URL'),

    equity_card_photo: z
      .string()
      .min(1, 'សូមថតរូបបណ្ណសមធម៌')
      .url('Invalid photo URL'),

    // NID photo (important for validation)
    nid_photo: z
      .string()
      .url('Invalid photo URL')
      .optional()
      .nullable(),

    fingerprints: z.string().optional(),

    is_disability_fingerprint: z.boolean().optional(),

    disability_fingerprint_photo: z.string().optional(),

    is_not_nid: z.boolean().optional(),
  })

  // ⭐ Conditional validation for NID
  .superRefine((data, ctx) => {
    const nid = data.national_id;
    const hasPhoto = !!data.nid_photo;

    if (hasPhoto) {
      // If NID photo exists → must be 9 digits
      if (!/^\d{9}$/.test(nid)) {
        ctx.addIssue({
          code: z.ZodIssueCode.custom,
          path: ['national_id'],
          message: 'បើមានរូបអត្តសញ្ញាណបណ្ណ សូមបញ្ចូលលេខ ៩ ខ្ទង់',
        });
      }
    } else {
      // If no NID photo → must be 10 digits
      if (!/^\d{10}$/.test(nid)) {
        ctx.addIssue({
          code: z.ZodIssueCode.custom,
          path: ['national_id'],
          message: 'បើគ្មានរូបអត្តសញ្ញាណបណ្ណ សូមបញ្ចូលលេខ ១០ ខ្ទង់',
        });
      }
    }
  });

export type MemberFormValues = z.infer<typeof memberSchema>;
