      .array(
        z.object({
          data: z.object({
            BMPBase64: z.string().optional(),
            ISOTemplateBase64: z.string().optional(),
          }),
        }),
      )
      .optional(),
  })
  .refine(
    data => {
      if (data.is_disability_fingerprint) {
        return !!data.disability_fingerprint_photo;
      }
      return !!data.fingerprints;
    },
    {
      message: 'សូមថតរូបភាពបញ្ជាក់ពីពិការភាព',
      path: ['disability_fingerprint_photo'],
    },
  )
  .refine(
    data => {
      if (!data.is_disability_fingerprint) {
        return !!data.fingerprints;
      }
      return true;
    },
    {
      message: MESSAGES.FINGERPRINT_GUIDELINE,
      path: ['fingerprints'],
    },
  );
  // Removed name_en requirement refinement

export type MemberFormValues = z.infer<typeof memberSchema>;


