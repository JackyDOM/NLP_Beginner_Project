    account_holder_photo: z.string().min(1, 'សូមថតរូបម្ចាស់គណនី').url('Invalid photo URL'), // Assuming you're storing the photo as a URL

    equity_card_photo: z.string().min(1, 'សូមថតរូបបណ្ណសមធម៌').url('Invalid photo URL'), // Assuming you're storing the photo as a URL

