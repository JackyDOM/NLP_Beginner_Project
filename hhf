# Filter status
    async def filter_status(self, db: AsyncSession, *, status: AccountStatus, skip: int = 0, limit: int = 100) -> List[Main]:
        """
        Filter Main records by status only
        """
        stmt = (
            select(Main)
            .where(
                Main.is_deleted == False,
                Main.status == status,
            )
            .order_by(Main.created_at.desc())
            .offset(skip)
            .limit(limit)
        )

        result = await db.execute(stmt)
        return result.scalars().all()

