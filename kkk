@router.post(
    "/complaints",
    summary="Create Complaint",
    response_model=None
)
async def create_complaint(
    complaint: ComplaintCreate,
    keycloak_user: Annotated[UserInSignInKeyCloak, Depends(get_user_info)],
    db: Annotated[AsyncSession, Depends(async_get_db)]
):
    try:
        logging.info("Authenticated user: %s", keycloak_user.username)

        db_user = await validate_user(keycloak_user.username, keycloak_user, db)
        user_id = db_user["id"]

        disability_name = None

        if complaint.is_disability:
            if not complaint.disability_card:
                return {"error": True, "message": "disability_card is required when is_disability is True"}

            complaint.disability_card = str(complaint.disability_card)
            if len(complaint.disability_card) > 100:
                return {"error": True, "message": "លេខបណ្ណ័ពិការភាពមិនត្រឹមត្រូវ!"}

            # Check duplicate complaint
            stmt = select(ComplaintTable).where(
                ComplaintTable.disability_card == complaint.disability_card,
                ComplaintTable.is_disability == True,
                ComplaintTable.is_deleted == False
            )
            result = await db.execute(stmt)
            existing_complaint = result.scalar_one_or_none()
            if existing_complaint:
                return {"error": True, "message": f"លេខបណ្ណ័ពិការភាព '{complaint.disability_card}' មានរួចហើយ!"}

            # Check if exists in Main table and get disability_name
            stmt = select(Main).where(Main.disability_code == complaint.disability_card)
            result = await db.execute(stmt)
            main_record = result.scalar_one_or_none()
            if not main_record:
                return {"error": True, "message": f"លេខបណ្ណ័ពិការភាព '{complaint.disability_card}' មិនមានក្នុងទិន្នន័យ!"}

            # Combine family_name + given_name
            disability_name = " ".join(filter(None, [main_record.family_name, main_record.given_name]))

        # --- Complaint Type Validation ---
        if complaint.complaint_type_id is not None:
            stmt = select(ComplaintTypeTable).where(
                ComplaintTypeTable.id == complaint.complaint_type_id,
                ComplaintTypeTable.is_deleted == False
            )
            result = await db.execute(stmt)
            complaint_type = result.scalar_one_or_none()
            if not complaint_type:
                return {"error": True, "message": "លេខសម្គាល់ ប្រភេទបណ្តឹងតវ៉ា ឬប្រភេទក្លែងបន្លំមិនត្រឹមត្រូវ!"}

        # --- Create Complaint ---
        complaint_internal = complaint.model_copy(
            update={
                "created_by": user_id,
                "updated_by": user_id,
                "submitted_at": complaint.submitted_at or datetime.utcnow(),
                "disability_name": disability_name
            }
        )

        created = await crud_complaint.create_complaint(
            db=db,
            complaint_data=complaint_internal
        )

        await db.commit()
        await db.refresh(created)

        response_data = {
            "id": created.id,
            "disability_card": created.disability_card,
            "disability_name": disability_name,
            "case_type": created.case_type,
            "complainant_name": created.complainant_name,
            "complainant_relation": created.complainant_relation,
            "receiver_name": created.receiver_name,
            "receiver_position": created.receiver_position,
            "complaint_type_id": created.complaint_type_id,
            "is_disability": created.is_disability
        }

        return {
            "error": False,
            "message": "Complaint created successfully",
            "data": response_data
        }

    except Exception as e:
        await db.rollback()
        logging.error("Error creating complaint: %s", str(e))
        return {"error": True, "message": "Internal server error"}



