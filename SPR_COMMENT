async def spr_register_pwd(payload: dict) -> dict:
    try:
        token = await _get_token()

        if not isinstance(token, dict):
            return {"error": True, "message": f"Invalid token: {token}", "user": None}

        access_token = token.get("access_token")

        if not access_token:
            return {"error": True, "message": "Missing access token", "user": None}

        url = f"{settings.SPR_CORE_SERVICE_URL}/api/v1/Portals/register/PWD"

        headers = {
            "Authorization": f"Bearer {access_token}",
            "Content-Type": "application/json",
            "Accept": "application/json",
        }

        body = {
            "username": settings.SPR_KEYCLOAK_USERNAME,
            "password": settings.SPR_KEYCLOAK_PASSWORD,
            "payload": payload
        }

        async with aiohttp.ClientSession() as session:
            async with session.post(
                url,
                data=json.dumps(body),
                headers=headers,
                timeout=60
            ) as response:

                status = response.status
                text = await response.text()

                logger.info("SPR STATUS: %s", status)
                logger.info("SPR RAW: %r", text)

                # ❗ EMPTY RESPONSE
                if not text or not text.strip():
                    return {
                        "error": True,
                        "message": "SPR returned empty response",
                        "user": None
                    }

                # ❗ TRY PARSE JSON
                try:
                    data = json.loads(text)
                except Exception:
                    return {
                        "error": True,
                        "message": f"SPR invalid JSON: {text}",
                        "user": None
                    }

                # ❗ NOT DICT
                if not isinstance(data, dict):
                    return {
                        "error": True,
                        "message": f"SPR returned non-dict: {data}",
                        "user": None
                    }

                # ❗ HANDLE STATUS
                if status not in [200, 201]:
                    return {
                        "error": True,
                        "message": data,
                        "user": None
                    }

                return data  # ✅ always dict

    except aiohttp.ClientError as e:
        logger.exception("SPR connection error ❌")
        return {
            "error": True,
            "message": str(e),
            "user": None
        }


