async def _spr_cleanup_test_data(equity_card_numbers: list[str]):
    """
    Internal function to call SPR cleanup test data endpoint.

    Args:
        equity_card_numbers: List of equity card numbers to clean up

    Returns:
        dict: Response from SPR service

    Raises:
        HTTPException: If there is an error communicating with the SPR service
    """
    try:
        # Get token for SPR service
        token = await _get_token()
        token = token.get("access_token", None)

        if not token:
            raise HTTPException(status_code=401, detail="Invalid access token")

        # Set up request to SPR service
        url = f"{spr_core_service_url}/Portals/cleanup-test-data"
        headers = {
            "Authorization": f"Bearer {token}",
            "Content-Type": "application/json",
        }

        # Format payload for SPR service
        spr_payload = {"equityCardNumbers": equity_card_numbers}

        logging.info(f"Calling SPR cleanup test data endpoint with {len(equity_card_numbers)} equity card numbers")

        payload_json = json.dumps(spr_payload)

        context_data = {"Equity Cards Count": len(equity_card_numbers)}

        async with aiohttp.ClientSession() as session:
            async with session.post(url, data=payload_json, headers=headers, timeout=60) as response:
                data = await _handle_api_error(
                    response,
                    SERVICE_SPR_CLEANUP_TEST_DATA,
                    "SPR CLEANUP ERROR",
                    context_data,
                    should_send_telegram_alert=True,
                )
                logging.info(
                    f"SPR cleanup test data completed successfully for {len(equity_card_numbers)} equity cards"
                )
                return data

    except aiohttp.ClientError as e:
        await _handle_connection_error(
            e,
            SERVICE_SPR_CLEANUP_TEST_DATA,
            {"Equity Cards Count": len(equity_card_numbers)},
        )
    except HTTPException:
        # Re-raise HTTP exceptions without modification
        raise
    except Exception as e:
        await _handle_unexpected_error(
            e,
            SERVICE_SPR_CLEANUP_TEST_DATA,
            {"Equity Cards Count": len(equity_card_numbers)},
        )


